{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CFMS Client",
  "version": "0.15.0",
  "identifier": "org.crpteam.cfms-client-tauri",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1909",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "CFMS Client",
        "width": 1280,
        "height": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "plugins": {
    "background-service": {}
  },
  "bundle": {
    "active": true,
    "android": {
      "autoIncrementVersionCode": false,
      "minSdkVersion": 24
    },
    "targets": "all",
    "resources": {
      "ca": "ca"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
